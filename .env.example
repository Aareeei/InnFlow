# Database
DATABASE_URL=postgresql://innflow:innflow@localhost:5432/innflow?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=innflow
S3_SECRET_KEY=innflowsecret
S3_BUCKET=innflow-artifacts
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# AI Provider (optional - mock is default)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Service URLs
CONTROL_API_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3000
MOCK_PMS_URL=http://localhost:3001

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=innflow

# Application
NODE_ENV=development
LOG_LEVEL=info
PORT_CONTROL_API=4000
PORT_DASHBOARD=3000
PORT_MOCK_PMS=3001

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
